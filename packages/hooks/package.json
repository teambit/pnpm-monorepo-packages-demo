{
  "name": "@evinova-demo/general.hooks",
  "version": "0.1.3",
  "description": "Reusable React hooks: useToggle, useDebounce",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/teambit/pnpm-monorepo-packages-demo",
    "directory": "packages/hooks"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false,
  "keywords": [
    "react",
    "hooks",
    "evinova-demo"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --sourcemap --clean",
    "test": "vitest run --environment jsdom"
  },
  "publishConfig": {
    "registry": "https://node-registry.bit.cloud",
    "access": "public"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.1.0",
    "jsdom": "^26.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  }
}
