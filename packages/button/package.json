{
  "name": "@evinova-demo/general.button",
  "version": "0.1.6",
  "description": "Themeable React button - primary, secondary and ghost variants",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/teambit/pnpm-monorepo-packages-demo",
    "directory": "packages/button"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src",
    "!src/**/*.test.*",
    "*.composition.tsx",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "keywords": [
    "react",
    "button",
    "design-system",
    "evinova-demo"
  ],
  "scripts": {
    "build": "tsup src/index.tsx --format esm,cjs --dts --sourcemap --clean"
  },
  "publishConfig": {
    "registry": "https://node-registry.bit.cloud",
    "access": "public"
  },
  "dependencies": {
    "@evinova-demo/general.theme": "workspace:*",
    "@evinova-demo/general.utils": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@types/react": "^19.1.0",
    "react": "^19.1.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.0"
  }
}
