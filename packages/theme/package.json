{
  "name": "@evinova-demo/theme",
  "version": "0.1.0",
  "description": "Design tokens (colors, spacing, radii, typography) for the Evinova demo design system",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/teambit/pnpm-monorepo-packages-demo",
    "directory": "packages/theme"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "keywords": ["design-tokens", "theme", "evinova-demo"],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "prepublishOnly": "pnpm build"
  },
  "publishConfig": {
    "registry": "https://node-registry.bit.cloud",
    "access": "public"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^5.8.0"
  }
}
