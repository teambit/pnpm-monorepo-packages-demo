{
  "name": "@evinova-demo/general.utils",
  "version": "0.1.4",
  "description": "Tiny framework-free utilities: class-name composition, truncation, date formatting",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/teambit/pnpm-monorepo-packages-demo",
    "directory": "packages/utils"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false,
  "keywords": [
    "utils",
    "classnames",
    "evinova-demo"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --sourcemap --clean",
    "test": "vitest run"
  },
  "publishConfig": {
    "registry": "https://node-registry.bit.cloud",
    "access": "public"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  }
}
