{
  "name": "pnpm-monorepo-packages-demo",
  "private": true,
  "description": "Demo: publishing packages from a plain pnpm monorepo to bit.cloud — no Bit tooling required",
  "license": "MIT",
  "packageManager": "pnpm@11.13.0",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r --if-present test",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish",
    "publish:all": "pnpm build && pnpm -r publish --batch --no-git-checks",
    "publish:dry": "pnpm build && pnpm -r publish --dry-run --no-git-checks"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.0"
  }
}
