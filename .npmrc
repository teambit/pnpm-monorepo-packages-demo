; ── The ONLY Bit integration in this repo ─────────────────────────────
; This file maps the @evinova-demo scope to the bit.cloud registry.
; Everything else falls through to the public npm registry.
; Credentials are configured user-level and never committed:
;   pnpm config set "//node-registry.bit.cloud/:_authToken" <token>
;   npm login --registry=https://node-registry.bit.cloud
@evinova-demo:registry=https://node-registry.bit.cloud
